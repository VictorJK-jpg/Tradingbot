# ===========================================
# PRODUCTION ENVIRONMENT - AWS Deployment
# ===========================================
# Copy this to .env on your AWS server
# Run: cp .env.production .env
# Then update the DATABASE_URL with your Supabase credentials

# Database (Supabase PostgreSQL with connection pooler)
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Security
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# Environment
ENVIRONMENT=production
DEBUG=false

# AI - Groq (free tier available)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Gemini (for advanced AI)
# GEMINI_API_KEY=
# AI_MODEL=gemini-2.0-flash

# Optional: CoinGecko (free tier)
# COINGECKO_API_KEY=

# User Limits
AI_CALL_BUDGET_PER_USER=50

# CORS (allow your mobile app)
ALLOWED_ORIGINS=http://localhost:3000,exp://localhost:19000